{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/vvvgo/tau2-purple-agent:latest",
    entrypoint: ["uv", "run", "src/server.py", "--host", "0.0.0.0", "--port", "9009"],
    env: {
      AGENT_MODEL: "${config.agent_model}",
      OPENAI_API_KEY: "${config.openai_api_key}",
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9009 }
      ]
    }
  },
  config_schema: {
    type: "object",
    properties: {
      agent_model: { type: "string", default: "gpt-5.4-mini" },
      openai_api_key: { type: "string", secret: true, default: "" },
    },
    required: [],
    additionalProperties: false,
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" }
  },
  exports: {
    a2a: "a2a"
  }
}
